# open_speakers worker — ML inference container
# Based on the vibevoice-timestamps image which already has:
#   - Python 3.12, torch 2.10+cu128, flash-attn 2.8.3, transformers 4.51.3
#   - vibevoice package installed at /app
#   - ffmpeg, libsndfile1
# We layer on: celery, redis, sqlalchemy, and additional TTS model packages.

FROM vibevoice-timestamps:latest AS base

USER root
WORKDIR /app

# System deps needed by OpenSpeakers that may not be in the base image
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    libpq-dev \
    espeak-ng \
    libsox-dev \
    cmake \
    make \
    gcc \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# ── OpenSpeakers backend deps (celery, DB, API framework) ──────────────────
RUN pip install --no-cache-dir \
    "fastapi>=0.115.0" \
    "uvicorn[standard]>=0.30.0" \
    "python-multipart>=0.0.9" \
    "websockets>=12.0" \
    "sqlalchemy>=2.0.30" \
    "alembic>=1.13.0" \
    "psycopg2-binary>=2.9.9" \
    "pydantic>=2.6.0" \
    "pydantic-settings>=2.3.0" \
    "celery>=5.4.0" \
    "redis[asyncio]>=5.0.0" \
    "httpx>=0.27.0" \
    "soundfile>=0.12.1" \
    "python-dotenv>=1.0.0"

# ── Kokoro TTS (82M — fast, < 1 GB VRAM, preset voices) ───────────────────
# Install pyopenjtalk prebuilt wheel first to avoid cmake build from source.
# misaki[ja] pulls in pyopenjtalk which requires cmake if built from source.
RUN pip install --no-cache-dir \
        "pyopenjtalk-prebuilt" || \
    pip install --no-cache-dir "pyopenjtalk"
RUN pip install --no-cache-dir "kokoro>=0.9.2" "misaki[ja]" "misaki[zh]" && \
    python -m spacy download en_core_web_sm

# ── Fish Speech ────────────────────────────────────────────────────────────
# Install from git with --no-deps to avoid torch/transformers version conflicts.
RUN pip install --no-cache-dir --no-deps \
    "git+https://github.com/fishaudio/fish-speech.git@main" && \
    pip install --no-cache-dir \
    "tiktoken>=0.8.0" \
    "descript-audio-codec" \
    "descript-audiotools" \
    "hydra-core>=1.3.2" \
    "einops>=0.7.0" \
    "silero-vad" \
    "loguru>=0.6.0"

# ── Qwen3 TTS ─────────────────────────────────────────────────────────────
RUN pip install --no-cache-dir --no-deps "qwen-tts>=0.1.1" && \
    pip install --no-cache-dir "vector_quantize_pytorch"

# ── Parler TTS Mini ───────────────────────────────────────────────────────
# Install with --no-deps to avoid downgrading transformers (parler-tts pins
# an older version but works fine with the newer transformers already installed).
RUN pip install --no-cache-dir --no-deps "parler-tts" && \
    pip install --no-cache-dir "sentencepiece"

# ── Speaker-similarity scoring (Phase 5) ───────────────────────────────────
# speechbrain ECAPA-TDNN runs on CPU inside worker-kokoro to score how close
# generated cloned audio sounds to the reference. librosa is needed by the
# shared reference-audio preprocessing helper.
RUN pip install --no-cache-dir \
    "speechbrain>=1.0.0" \
    "librosa>=0.10.0"

# ── Application code ───────────────────────────────────────────────────────
# Copy OpenSpeakers backend code (overrides /app from base image)
COPY . .

RUN mkdir -p /app/audio_output /home/appuser/.cache && \
    chown -R 1000:1000 /app/audio_output /home/appuser

ENV HOME=/home/appuser
ENV HF_HOME=/home/appuser/.cache/huggingface

USER 1000
