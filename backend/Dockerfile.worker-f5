# F5-TTS / Chatterbox / CosyVoice 2.0 / Parler TTS combined worker
# Listens on the `tts.f5-tts` Celery queue.
#
# Build base first:
#   docker build -t open_speakers-gpu-base:latest \
#     -f Dockerfile.base-gpu .

FROM open_speakers-gpu-base:latest

WORKDIR /app

# F5-TTS + Vocos vocoder (required by F5-TTS at load time)
RUN pip install --no-cache-dir "f5-tts"
# Pre-download the Vocos vocoder that F5-TTS requires (small, ~50MB)
RUN python3 -c "from huggingface_hub import snapshot_download; snapshot_download('charactr/vocos-mel-24khz')"

# Chatterbox TTS
RUN pip install --no-cache-dir "chatterbox-tts"

# Parler TTS Mini + transformers for tokenizer
RUN pip install --no-cache-dir "parler-tts" "transformers"

# CosyVoice 2.0 — clone repo (no setup.py; must be on PYTHONPATH)
# Install only the inference-critical subset (skips gradio/deepspeed/modelscope extras)
RUN git clone --recursive --depth=1 \
    https://github.com/FunAudioLLM/CosyVoice.git /opt/cosyvoice
RUN pip install --no-cache-dir \
    "HyperPyYAML>=1.2.3" \
    "modelscope>=1.20.0" \
    "onnxruntime>=1.18.0" \
    "openai-whisper>=20231117" \
    "inflect>=7.3.1" \
    "conformer==0.3.2" \
    "omegaconf>=2.3.0" \
    "hydra-core>=1.3.2" \
    "pyworld>=0.3.4" \
    "lightning>=2.2.4" \
    "gdown>=5.1.0" \
    "wget"

# OpenSpeakers backend deps
RUN pip install --no-cache-dir \
    "celery>=5.4.0" \
    "redis>=5.0.0" \
    "sqlalchemy>=2.0.30" \
    "alembic>=1.13.0" \
    "psycopg2-binary>=2.9.9" \
    "pydantic>=2.6.0" \
    "pydantic-settings>=2.3.0" \
    "python-dotenv>=1.0.0" \
    "fastapi>=0.115.0"

# Application code
COPY . .

RUN mkdir -p /app/audio_output
