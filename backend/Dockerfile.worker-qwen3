# Qwen3 TTS worker — separate container because qwen-tts needs transformers 5.x
# (the main worker pins transformers 4.51.3 for VibeVoice compatibility)
#
# Build base first:
#   docker build -t open_speakers-gpu-base:latest \
#     -f Dockerfile.base-gpu .

FROM open_speakers-gpu-base:latest

WORKDIR /app

# Qwen3 TTS — installs its own transformers version; accelerate already in base
RUN pip install --no-cache-dir \
    "qwen-tts" \
    "vector_quantize_pytorch"

# OpenSpeakers backend deps (celery, DB, API framework)
RUN pip install --no-cache-dir \
    "celery>=5.4.0" \
    "redis>=5.0.0" \
    "sqlalchemy>=2.0.30" \
    "alembic>=1.13.0" \
    "psycopg2-binary>=2.9.9" \
    "pydantic>=2.6.0" \
    "pydantic-settings>=2.3.0" \
    "python-dotenv>=1.0.0"

# Application code
COPY . .

RUN mkdir -p /app/audio_output
